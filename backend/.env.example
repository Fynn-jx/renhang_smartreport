# ==================== 应用配置 ====================
APP_NAME=公文写作AI系统
APP_VERSION=1.0.0
DEBUG=True
ENVIRONMENT=development

# 服务地址
API_HOST=0.0.0.0
API_PORT=8000
API_PREFIX=/api/v1

# ==================== 数据库配置 ====================
# PostgreSQL
DATABASE_URL=postgresql+asyncpg://user:password@localhost:5432/docwriting
DATABASE_URL_SYNC=postgresql+psycopg2://user:password@localhost:5432/docwriting

# ==================== Redis 配置 ====================
REDIS_URL=redis://localhost:6379/0
REDIS_PASSWORD=

# ==================== 文件存储配置 ====================
# 存储路径（相对于项目根目录）
STORAGE_ROOT=./storage
UPLOAD_DIR=./storage/uploads
THUMBNAIL_DIR=./storage/thumbnails
CACHE_DIR=./storage/cache

# 文件大小限制（MB）
MAX_FILE_SIZE=100
MAX_IMAGE_SIZE=10

# ==================== AI 服务配置 ====================
# 硅基流动 DeepSeek
SILICONFLOW_API_KEY=your_siliconflow_api_key_here
SILICONFLOW_BASE_URL=https://api.siliconflow.cn/v1
DEEPSEEK_MODEL=Pro/deepseek-ai/DeepSeek-V3
DEEPSEEK_R1_MODEL=deepseek-ai/DeepSeek-R1

# OpenRouter (图片转译)
OPENROUTER_API_KEY=your_openrouter_api_key_here
OPENROUTER_BASE_URL=https://openrouter.ai/api/v1
OPENROUTER_IMAGE_MODEL=google/gemini-3-pro-image-preview

# ==================== 向量检索配置 ====================
# 向量数据库类型: pgvector 或 qdrant
VECTOR_STORE_TYPE=pgvector

# Qdrant 配置（如果使用 Qdrant）
QDRANT_HOST=localhost
QDRANT_PORT=6333
QDRANT_COLLECTION_NAME=knowledge_base

# ==================== 任务队列配置 ====================
# Celery Broker
CELERY_BROKER_URL=redis://localhost:6379/1
CELERY_RESULT_BACKEND=redis://localhost:6379/2

# ==================== 安全配置 ====================
# JWT 密钥（生产环境必须修改！）
SECRET_KEY=your-secret-key-change-in-production
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=60

# ==================== CORS 配置 ====================
ALLOWED_ORIGINS=http://localhost:3000,http://localhost:5173
ALLOWED_METHODS=*
ALLOWED_HEADERS=*

# ==================== 日志配置 ====================
LOG_LEVEL=INFO
LOG_FILE=./logs/app.log

# ==================== Firecrawl 配置 ====================
FIRECRAWL_API_KEY=your_firecrawl_api_key_here
FIRECRAWL_BASE_URL=https://api.firecrawl.dev

# ==================== 知识库配置 ====================
# 知识库检索的 Top-K
KNOWLEDGE retrieval_TOP_K=5
KNOWLEDGE_RERANK_ENABLED=True
